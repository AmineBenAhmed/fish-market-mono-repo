# ─── Development ────────────────────────────────────────────
FROM node:20-alpine

RUN corepack enable && corepack prepare pnpm@9 --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages ./packages
COPY apps ./apps

RUN pnpm install

EXPOSE 3000 3001 3002

CMD ["pnpm", "dev"]
