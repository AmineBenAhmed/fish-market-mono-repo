// ═══════════════════════════════════════════════════════════════
//  FishMarket — Complete Domain Schema
// ═══════════════════════════════════════════════════════════════
//
//  Architecture decisions:
//
//  1. String CUIDs everywhere — avoids auto-increment leaks,
//     works across microservices, makes sharding trivial.
//
//  2. Soft delete with deletedAt on User only —
//     orders reference historical data that must not disappear.
//
//  3. OrderStatusHistory and DeliveryStatusHistory are
//     append-only tables. Every transition is immutable.
//
//  4. AuditLog stores JSON diffs for sensitive mutations
//     (price changes, cancellations, status overrides).
//
//  5. DailyInventory decouples "what a seller sells" from
//     "what they have today" — critical for fresh fish where
//     stock changes daily.
//
//  6. Payment stores the full gateway response as JSON for
//     debugging and reconciliation.
//
//  7. Wallet + Transaction implements double-entry accounting
//     for seller payouts and customer refunds.
//
//  8. No composite foreign keys — Prisma handles them.
//     All relations use explicit @relation + fields for clarity.
//
// ═══════════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
//  ENUMS
// ═══════════════════════════════════════════════════════════════

enum UserRole {
  CUSTOMER
  SELLER
  DRIVER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum OrderStatus {
  DRAFT               // Created from cart, items reserved
  PENDING             // Checked out, awaiting payment
  CONFIRMED           // Paid, seller accepted
  PREPARING           // Seller packing the fish
  READY_FOR_PICKUP    // Packed, waiting for driver
  OUT_FOR_DELIVERY    // Driver en route
  DELIVERED           // Customer received
  CANCELLED           // Cancelled (before delivery)
  REFUNDED            // Money returned to customer
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  CASH
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  DECLINED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum DeliveryStatus {
  PENDING_ASSIGNMENT
  ASSIGNED         // Driver assigned
  ACCEPTED         // Driver accepted
  PICKING_UP       // Driver heading to seller
  PICKED_UP        // Driver picked up from seller
  IN_TRANSIT       // En route to customer
  DELIVERED        // Customer received
  FAILED           // Could not deliver
  RETURNED         // Returned to seller
  CANCELLED        // Cancelled
}

enum FishSize {
  SMALL
  MEDIUM
  LARGE
  EXTRA_LARGE
}

enum QualityGrade {
  PREMIUM
  STANDARD
  ECONOMY
}

enum InventoryUnit {
  KG
  G
  UNIT
  DOZEN
}

enum Preservation {
  FRESH
  CHILLED
  FROZEN
  SALTED
  SMOKED
  PREPARED
}

enum ListingStatus {
  PENDING
  ACTIVE
  REJECTED
  OUT_OF_STOCK
  EXPIRED
}

enum TransactionType {
  ORDER_PAYMENT     // Customer pays for an order
  COMMISSION        // Marketplace commission
  DELIVERY_FEE      // Delivery service fee
  SELLER_EARNING    // Seller receives payment for goods
  WITHDRAWAL        // User withdraws funds
  DEPOSIT           // User deposits funds
  REFUND            // Money returned to customer
  COUPON_DISCOUNT   // Promotional discount
  WALLET_CREDIT     // Generic wallet credit
  WALLET_DEBIT      // Generic wallet debit
  ADJUSTMENT        // Manual ledger adjustment
}

enum BillingType {
  CUSTOMER_RECEIPT
  SELLER_SETTLEMENT
  MARKETPLACE_REPORT
}

enum BillingStatus {
  PENDING
  GENERATED
  SENT
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
}

enum SellerVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum DriverStatus {
  ONLINE
  OFFLINE
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
}

enum NotificationType {
  ACCOUNT_CREATED
  ORDER_CONFIRMED
  ORDER_PREPARING
  ORDER_OUT_FOR_DELIVERY
  ORDER_DELIVERED
  ORDER_CANCELLED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  NEW_REVIEW
  NEW_MESSAGE
  PROMOTION
  SELLER_APPROVED
  DRIVER_ACTIVATED
  WITHDRAWAL_COMPLETED
  LOW_INVENTORY
}

// ═══════════════════════════════════════════════════════════════
//  USER & PROFILE DOMAIN
// ═══════════════════════════════════════════════════════════════

/// Core identity. Soft-deletable to preserve historical references.
model User {
  id             String   @id @default(cuid())
  code           String?  @unique
  email          String   @unique
  passwordHash   String
  name           String
  phone          String?
  avatarFileId   String?   @unique
  role           UserRole @default(CUSTOMER)
  status         UserStatus @default(ACTIVE)
  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)
  lastLoginAt    DateTime?
  resetToken     String?  @unique
  resetTokenExpiresAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  // Relations
  refreshTokens   RefreshToken[]
  avatarFile       File?          @relation("UserAvatar", fields: [avatarFileId], references: [id], onDelete: SetNull)
  customerProfile CustomerProfile?
  sellerProfiles  SellerProfile[]
  driverProfile   DriverProfile?
  setting         UserSetting?
  addresses       UserAddress[]
  cart            Cart?
  orders          Order[]        @relation("CustomerOrders")
  sellerOrders    Order[]        @relation("SellerOrders")
  cancelledOrders Order[]        @relation("CancelledBy")
  driverDeliveries Delivery[]    @relation("DriverDeliveries")
  orderStatusChanges OrderStatusHistory[] @relation("OrderStatusChangedBy")
  reviews         Review[]
  wallet          Wallet?
  notifications   Notification[]
  uploads         File[]         @relation("FileUploader")
  auditLogs       AuditLog[]

  @@index([email])
  @@index([role, status])
  @@index([deletedAt])
}

/// Refresh tokens for JWT authentication with rotation support.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  jti       String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jti])
  @@index([expiresAt])
}

/// Customer-specific profile. Created automatically for every user.
model CustomerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  defaultAddressId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultAddress  UserAddress? @relation("DefaultAddress", fields: [defaultAddressId], references: [id], onDelete: SetNull)

  @@index([userId])
}

/// User preferences and settings.
model UserSetting {
  id                String  @id @default(cuid())
  userId            String  @unique
  language          String  @default("pt-BR")
  theme             String  @default("light")
  marketingOptIn    Boolean @default(false)
  notifyOrderUpdates Boolean @default(true)
  notifyPromotions  Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Extended profile for sellers.
model SellerProfile {
  id                 String                  @id @default(cuid())
  userId             String
  storeName          String
  storeDescription   String?
  storeLogoFileId    String?                 @unique
  deliveryRadius     Int                     @default(10)
  commissionRate     Float                   @default(0)
  preparationTime    Int                     @default(30)
  verificationStatus SellerVerificationStatus @default(PENDING)
  businessName       String?
  businessDoc        String?
  taxId              String?
  photo              String?
  storeLogoUrl       String?
  isActive           Boolean                 @default(false)
  city               String
  state              String
  lat                Float?
  lng                Float?
  pickupAddress      String?
  deliveryZoneId     String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  // Relations
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeLogo       File?           @relation("StoreLogo", fields: [storeLogoFileId], references: [id], onDelete: SetNull)
  listings        SellerListing[]
  zone            DeliveryZone?   @relation("SellerZones", fields: [deliveryZoneId], references: [id])
}

/// Extended profile for drivers.
model DriverProfile {
  id            String       @id @default(cuid())
  userId        String       @unique
  status        DriverStatus @default(OFFLINE)
  isAvailable   Boolean      @default(true)
  currentLat       Float?
  currentLng       Float?
  city             String
  state            String
  deliveryZoneId   String?
  lastLocationAt   DateTime?     // timestamp of last GPS update
  activeDeliveries Int           @default(0)   // current active delivery count
  maxDeliveries    Int           @default(1)   // max simultaneous deliveries
  vehicleType      String?
  vehiclePlate     String?
  licenseNumber    String?
  maxLoadKg        Float?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone     DeliveryZone? @relation("DriverZones", fields: [deliveryZoneId], references: [id])
  @@index([city, state])
}

/// User addresses. Geocoded for delivery radius calculation.
model UserAddress {
  id           String   @id @default(cuid())
  userId       String
  label        String?  // "Home", "Work", etc.
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  lat          Float?
  lng          Float?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries        Delivery[]
  customerProfiles  CustomerProfile[] @relation("DefaultAddress")

  @@index([userId])
  @@index([city, state])
}

// ═══════════════════════════════════════════════════════════════
//  PRODUCT DOMAIN — Catalog + Daily Listings
// ═══════════════════════════════════════════════════════════════
//
//  Architecture notes:
//
//  1. FishProduct is the MASTER CATALOG — not seller-specific.
//     It defines the fish type (e.g., "Sea Bass", "Sardines").
//
//  2. FishVariant defines the sellable units of a product
//     (e.g., "Whole 1kg", "Fillet 500g", "Box 2kg").
//
//  3. SellerListing is the per-seller, per-day, per-variant
//     declaration of price + stock. Inventory resets daily.
//
//  4. Past listings are kept for audit and analytics but
//     are automatically marked EXPIRED after the day ends.
//
//  5. Price, quantity, and availability are DECOUPLED from
//     the product — they live on SellerListing only.
//
// ═══════════════════════════════════════════════════════════════

/// Hierarchical fish categories. Self-referencing for subcategories.
model FishCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageFileId String?   @unique
  imageUrl    String?
  parentId    String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  parent     FishCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   FishCategory[] @relation("CategoryHierarchy")
  image      File?         @relation("CategoryImage", fields: [imageFileId], references: [id], onDelete: SetNull)
  products   FishProduct[]
  listings   SellerListing[]

  @@index([parentId])
  @@index([slug])
  @@index([sortOrder])
}

/// Master catalog of fish types. NOT seller-specific.
/// Represents what CAN be sold (e.g., Sea Bass, Sardines, Shrimp).
model FishProduct {
  id             String        @id @default(cuid())
  categoryId     String
  name           String
  slug           String        @unique
  description    String?
  origin         String?       // general origin info
  preservation   Preservation? @default(FRESH)
  qualityGrade   QualityGrade  @default(STANDARD)
  unitType       InventoryUnit @default(KG) // default selling unit
  marketPriceMin Decimal?      @db.Decimal(10, 2) // reference price floor
  marketPriceMax Decimal?      @db.Decimal(10, 2) // reference price ceiling
  isActive       Boolean       @default(true)
  imageFileId    String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  category   FishCategory   @relation(fields: [categoryId], references: [id])
  image      File?          @relation("ProductImage", fields: [imageFileId], references: [id], onDelete: SetNull)
  variants   FishVariant[]
  reviews    Review[]

  @@index([categoryId, isActive])
  @@index([slug])
  @@index([name])
}

/// Sellable units of a product (e.g., "Whole 1kg", "Fillet 500g").
model FishVariant {
  id          String        @id @default(cuid())
  productId   String
  name        String        // e.g., "500g Fillet", "Whole 1kg", "Box 2kg"
  description String?
  unit        InventoryUnit
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  product      FishProduct      @relation(fields: [productId], references: [id], onDelete: Cascade)
  listings     SellerListing[]
  cartItems    CartItem[]
  orderItems   OrderItem[]

  @@index([productId])
}

/// Daily seller listing — the core of fresh fish commerce.
/// Every seller publishes their available stock per variant per day.
/// Inventory resets daily. Past listings are marked EXPIRED.
model SellerListing {
  id        String        @id @default(cuid())
  sellerId  String
  categoryId String
  variantId String?
  date      DateTime      @db.Date
  price     Decimal       @db.Decimal(10, 2)
  quantity  Int           // units available for the day
  status    ListingStatus @default(PENDING)
  notes     String?
  title     String?
  description String?
  catchDate   DateTime?
  availabilityDate DateTime?
  origin     String?
  condition  Preservation    @default(FRESH)
  averageWeight Decimal?     @db.Decimal(8, 2)
  cleaningCost Decimal       @default(0) @db.Decimal(10, 2)
  unit       String?
  currency   String          @default("TND")
  coverImageId String?   @unique
  imageUrls  String[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  seller     SellerProfile   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category   FishCategory    @relation(fields: [categoryId], references: [id])
  variant    FishVariant?    @relation(fields: [variantId], references: [id])
  coverImage File?           @relation("ListingCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)
  images     ListingImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([sellerId, date, status])
  @@index([categoryId, date, status])
  @@index([date, status])
  @@index([status])
}

/// Images attached to a listing. Up to 4 per listing.
model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  fileId    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  listing SellerListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  file    File          @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([listingId, fileId])
  @@index([listingId])
}

// ═══════════════════════════════════════════════════════════════
//  SHOPPING CART DOMAIN
// ═══════════════════════════════════════════════════════════════

/// One active cart per customer. Cart becomes Order on checkout.
model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  listingId String
  variantId String
  quantity  Int
  createdAt DateTime @default(now())

  // Relations
  cart    Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  listing SellerListing @relation(fields: [listingId], references: [id])
  variant FishVariant   @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([listingId])
}

// ═══════════════════════════════════════════════════════════════
//  ORDER DOMAIN
// ═══════════════════════════════════════════════════════════════

/// Core order. Parent for marketplace split. References customer.
/// For multi-seller carts: parent (sellerId=null) + children (parentOrderId set).
/// For single-seller: single order (parentOrderId=null, sellerId set).
model Order {
  id              String      @id @default(cuid())
  parentOrderId   String?
  orderNumber     String      @unique // human-readable: "FM-20240101-XXXX"
  customerId      String
  sellerId        String?     // null for parent orders in multi-seller splits
  status          OrderStatus @default(DRAFT)
  subtotal        Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @db.Decimal(10, 2)
  commission      Decimal     @db.Decimal(10, 2)
  discount        Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  notes           String?
  cancelReason    String?
  cancelledById   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  parentOrder  Order?              @relation("OrderHierarchy", fields: [parentOrderId], references: [id])
  childOrders  Order[]             @relation("OrderHierarchy")
  customer     User                @relation("CustomerOrders", fields: [customerId], references: [id])
  seller       User?               @relation("SellerOrders", fields: [sellerId], references: [id])
  cancelledBy  User?               @relation("CancelledBy", fields: [cancelledById], references: [id])
  items        OrderItem[]
  statusHistory OrderStatusHistory[]
  payment      Payment?
  delivery     Delivery?
  coupon       OrderCoupon?
  review       Review?
  billings     Billing[]

  @@index([customerId, status])
  @@index([sellerId, status])
  @@index([parentOrderId])
  @@index([status, createdAt])
  @@index([orderNumber])
  @@index([createdAt])
}

/// Snapshot of what was ordered. References variant + listing for historical data.
model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  listingId   String? // nullable for backward compat
  variantId   String? // null if no variant assigned to listing
  sellerId    String  // denormalized for per-seller queries
  productName String  // snapshot at order time
  variantName String  // snapshot at order time
  quantity    Int
  unit        InventoryUnit
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  cleaning    Boolean @default(false)

  // Relations
  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing SellerListing? @relation(fields: [listingId], references: [id])
  variant FishVariant?   @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([listingId])
  @@index([variantId])
  @@index([sellerId])
}

/// Immutable audit trail of every status change.
model OrderStatusHistory {
  id         String      @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedById String?
  reason     String?
  createdAt  DateTime    @default(now())

  // Relations
  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User? @relation("OrderStatusChangedBy", fields: [changedById], references: [id])

  @@index([orderId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
//  PAYMENT DOMAIN
// ═══════════════════════════════════════════════════════════════

/// Payment record. Stores gateway response for reconciliation.
model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(10, 2)
  transactionId   String?       // gateway transaction ID
  gatewayResponse Json?         // full gateway response
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([transactionId])
}

// ═══════════════════════════════════════════════════════════════
//  DELIVERY DOMAIN
// ═══════════════════════════════════════════════════════════════

/// Delivery tracking. Assigned to a driver.
model Delivery {
  id              String         @id @default(cuid())
  orderId         String         @unique
  addressId       String
  driverId        String?
  status          DeliveryStatus @default(PENDING_ASSIGNMENT)
  scheduledDate   DateTime?      @db.Date
  scheduledTime   String?        // "14:00-16:00" time window
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  failedAt        DateTime?
  failReason      String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  order          Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  address        UserAddress             @relation(fields: [addressId], references: [id])
  driver         User?                   @relation("DriverDeliveries", fields: [driverId], references: [id])
  statusHistory  DeliveryStatusHistory[]

  @@index([driverId, status])
  @@index([driverId, status, createdAt])
  @@index([status, scheduledDate])
  @@index([status, createdAt])
  @@index([scheduledDate])
}

/// Immutable delivery status audit trail.
model DeliveryStatusHistory {
  id         String         @id @default(cuid())
  deliveryId String
  fromStatus DeliveryStatus?
  toStatus   DeliveryStatus
  createdAt  DateTime       @default(now())

  // Relations
  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
}

// ═══════════════════════════════════════════════════════════════
//  DELIVERY ZONE DOMAIN
// ═══════════════════════════════════════════════════════════════

/// Delivery zones for geographic dispatch. Polygon-ready for future GIS.
model DeliveryZone {
  id        String   @id @default(cuid())
  name      String
  city      String?
  region    String?
  polygon   Json?    // GeoJSON polygon for future GIS integration
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  drivers DriverProfile[] @relation("DriverZones")
  sellers SellerProfile[] @relation("SellerZones")

  @@index([city])
  @@index([isActive])
}

// ═══════════════════════════════════════════════════════════════
//  REVIEW DOMAIN
// ═══════════════════════════════════════════════════════════════

model Review {
  id        String   @id @default(cuid())
  productId String
  orderId   String   @unique // one review per order per product
  userId    String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  product FishProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  order   Order       @relation(fields: [orderId], references: [id])
  user    User        @relation(fields: [userId], references: [id])

  @@unique([productId, userId, orderId])
  @@index([productId, rating])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
//  COUPON DOMAIN
// ═══════════════════════════════════════════════════════════════

model Coupon {
  id            String     @id @default(cuid())
  code          String     @unique
  type          CouponType
  value         Decimal    @db.Decimal(10, 2) // percentage or fixed amount
  minPurchase   Decimal?   @db.Decimal(10, 2) // minimum order value
  maxDiscount   Decimal?   @db.Decimal(10, 2) // cap for percentage coupons
  usageLimit    Int?       // total uses allowed
  usedCount     Int        @default(0)
  expiresAt     DateTime?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  orders OrderCoupon[]

  @@index([code])
  @@index([isActive, expiresAt])
}

/// Tracks coupon usage per order.
model OrderCoupon {
  id        String   @id @default(cuid())
  orderId   String   @unique
  couponId  String
  discount  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  // Relations
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id])

  @@index([couponId])
}

// ═══════════════════════════════════════════════════════════════
//  WALLET & FINANCE DOMAIN
// ═══════════════════════════════════════════════════════════════

/// One wallet per user (sellers for payouts, customers for refunds).
/// Wallets represent accounting balances — they do not process payments directly.
/// - balance: settled funds available for withdrawal
/// - pendingBalance: funds from orders in transit (not yet settled)
/// - availableBalance: total - pending (computed via trigger/service)
model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  balance          Decimal  @default(0) @db.Decimal(12, 2)
  pendingBalance   Decimal  @default(0) @db.Decimal(12, 2)
  availableBalance Decimal  @default(0) @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

/// Double-entry accounting. Every transaction records before/after balance.
model Transaction {
  id             String          @id @default(cuid())
  walletId       String
  type           TransactionType
  amount         Decimal         @db.Decimal(12, 2)
  referenceType  String?         // "order", "withdrawal", etc.
  referenceId    String?         // order ID, withdrawal ID, etc.
  description    String?
  balanceBefore  Decimal         @db.Decimal(12, 2)
  balanceAfter   Decimal         @db.Decimal(12, 2)
  createdAt      DateTime        @default(now())

  // Relations
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
//  BILLING DOMAIN — Invoices, Receipts, Settlement Statements
// ═══════════════════════════════════════════════════════════════

/// Invoice/receipt records for customers and settlement statements for sellers.
/// PDF generation can be added later by storing the URL in documentUrl.
model Billing {
  id          String        @id @default(cuid())
  orderId     String
  type        BillingType
  number      String        @unique
  amount      Decimal       @db.Decimal(10, 2)
  status      BillingStatus @default(PENDING)
  documentUrl String?
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([type, status])
  @@index([number])
}

// ═══════════════════════════════════════════════════════════════
//  NOTIFICATION DOMAIN
// ═══════════════════════════════════════════════════════════════

model Notification {
  id        String             @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String?
  data      Json?              // flexible payload
  isRead    Boolean            @default(false)
  readAt    DateTime?
  createdAt DateTime           @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

// ═══════════════════════════════════════════════════════════════
//  FILE & STORAGE DOMAIN
// ═══════════════════════════════════════════════════════════════

/// Tracks all uploaded files. Supports local and S3 storage via config.
model File {
  id           String   @id @default(cuid())
  userId       String?
  originalName String
  mimeType     String
  size         Int      // bytes
  path         String   // storage path
  url          String?  // public URL
  createdAt    DateTime @default(now())

  // Relations
  uploader        User?           @relation("FileUploader", fields: [userId], references: [id])
  userAvatar      User?           @relation("UserAvatar")
  storeLogo       SellerProfile?  @relation("StoreLogo")
  categoryImage   FishCategory?   @relation("CategoryImage")
  productImage    FishProduct?    @relation("ProductImage")
  listingCoverImage SellerListing? @relation("ListingCoverImage")
  listingImages     ListingImage[]

  @@index([userId])
  @@index([mimeType])
}

// ═══════════════════════════════════════════════════════════════
//  AUDIT & PLATFORM DOMAIN
// ═══════════════════════════════════════════════════════════════

/// Captures every sensitive mutation for compliance and debugging.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // "CREATE", "UPDATE", "DELETE", "CANCEL", "REFUND"
  entity     String   // "Order", "Product", "Payment", "User"
  entityId   String
  oldValue   Json?    // state before
  newValue   Json?    // state after
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([action, createdAt])
  @@index([createdAt])
}

/// Key-value store for platform-wide configuration.
model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}
