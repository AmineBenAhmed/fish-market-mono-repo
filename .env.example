# ─── Application ───────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── API ───────────────────────────────────────────────────
API_URL=http://localhost:4000
APP_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://fishmarket:fishmarket@localhost:5432/fishmarket
REDIS_URL=redis://localhost:6379

# ─── Authentication ────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=7d

# ─── Payments (Stripe) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email ─────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Storage (AWS S3) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ─── Google Maps ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
